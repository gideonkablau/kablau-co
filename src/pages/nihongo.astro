const DECKS = [
  { id:'hiragana', label:'Hiragana' },
  { id:'katakana', label:'Katakana' },
  { id:'kanji',    label:'Kanji' },
  { id:'all',      label:'All' },
];

let active = new Set(['hiragana']);
let queue = [], idx = 0, flipped = false;

function shuffle(a) {
  const b=[...a];
  for(let i=b.length-1;i>0;i--){const j=Math.random()*(i+1)|0;[b[i],b[j]]=[b[j],b[i]];}
  return b;
}

function buildQueue() {
  let cards=[];
  if(active.has('all')){
    cards=[...hiragana.map(c=>({...c,deck:'Hiragana'})),...katakana.map(c=>({...c,deck:'Katakana'})),...kanji.map(c=>({...c,deck:'Kanji'}))];
  } else {
    if(active.has('hiragana')) cards.push(...hiragana.map(c=>({...c,deck:'Hiragana'})));
    if(active.has('katakana')) cards.push(...katakana.map(c=>({...c,deck:'Katakana'})));
    if(active.has('kanji'))    cards.push(...kanji.map(c=>({...c,deck:'Kanji'})));
  }
  queue=shuffle(cards); idx=0; flipped=false;
}

function renderDecks() {
  const el=document.getElementById('deckSelector'); el.innerHTML='';
  DECKS.forEach(d=>{
    const b=document.createElement('button');
    b.className='deck-btn'+(active.has(d.id)?' active':'');
    b.dataset.id=d.id;
    b.innerHTML=d.label;
    b.addEventListener('click',()=>toggle(d.id));
    el.appendChild(b);
  });
}

function toggle(id) {
  if(id==='all'){active.clear();active.add('all');}
  else{active.delete('all');active.has(id)?active.delete(id):active.add(id);}
  if(!active.size) active.add(id);
  buildQueue(); renderDecks(); renderCard();
}

function renderCard() {
  const area=document.getElementById('cardArea');
  if(!queue.length){area.innerHTML='<p style="color:var(--muted);text-align:center;padding:3rem 0;font-size:14px;">No deck selected.</p>';return;}
  if(idx>=queue.length){
    area.innerHTML=`
      <div class="done-screen">
        <div class="done-kanji">完</div>
        <div class="done-title">Round complete</div>
        <div class="done-sub">You went through all ${queue.length} cards.<br>Ready for another round?</div>
        <button class="restart-btn" id="restartBtn">Shuffle again</button>
      </div>`;
    document.getElementById('restartBtn').addEventListener('click', restart);
    return;
  }
  const card=queue[idx];
  const pct=Math.round((idx/queue.length)*100);
  area.innerHTML=`
    <div class="scene" id="scene" role="button" aria-label="Flip card">
      <div class="card-inner" id="ci">
        <div class="face front">
          <span class="deck-badge">${card.deck}</span>
          <span class="char">${card.c}</span>
          <span class="face-hint">Tap to reveal</span>
        </div>
        <div class="face back">
          <span class="deck-badge">${card.deck}</span>
          <span class="romaji">${card.r}</span>
          <span class="char-back">${card.c}</span>
          ${card.m ? `<span class="meaning">${card.m}</span>` : ''}
        </div>
      </div>
    </div>
    <div class="controls">
      <button class="nav-btn" id="prevBtn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
        Back
      </button>
      <div class="progress">
        <div class="progress-count">${idx+1} / ${queue.length}</div>
        <div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>
      </div>
      <button class="nav-btn" id="nextBtn">
        Next
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>`;
  document.getElementById('scene').addEventListener('click', flip);
  document.getElementById('prevBtn').addEventListener('click', prev);
  document.getElementById('nextBtn').addEventListener('click', next);
  flipped=false;
}

function flip(){flipped=!flipped;const ci=document.getElementById('ci');if(ci)ci.classList.toggle('flipped',flipped);}
function next(){idx++;renderCard();}
function prev(){if(idx>0){idx--;renderCard();}}
function restart(){buildQueue();renderCard();}

document.addEventListener('keydown',e=>{
  if(e.key===' '||e.key==='Enter'){e.preventDefault();flip();}
  else if(e.key==='ArrowRight')next();
  else if(e.key==='ArrowLeft')prev();
});

buildQueue(); renderDecks(); renderCard();
</script>

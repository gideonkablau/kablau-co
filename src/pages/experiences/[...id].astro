---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const experiences = await getCollection("experiences", ({ data }) => !data.draft);
  return experiences.map((exp) => ({
    params: { id: exp.id },
    props: { exp },
  }));
}

const { exp } = Astro.props;
const { Content } = await render(exp);
---

<Base title={exp.data.title} description={exp.data.description}>
  <article>
    <header class="page-header">
      <h1>{exp.data.title}</h1>
      <time datetime={exp.data.date.toISOString()}>
        {exp.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
      </time>
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</Base>
